{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      { "source": "/index.html", "destination": "/", "type": 301 },
      { "source": "/about.html", "destination": "/about", "type": 301 },
      { "source": "/events.html", "destination": "/events", "type": 301 },
      { "source": "/projects.html", "destination": "/projects", "type": 301 },
      { "source": "/join.html", "destination": "/join", "type": 301 },
      { "source": "/bod.html", "destination": "/bod", "type": 301 },
      { "source": "/faq.html", "destination": "/faq", "type": 301 },
      { "source": "/contact.html", "destination": "/contact", "type": 301 },
      { "source": "/login.html", "destination": "/login", "type": 302 },
      { "source": "/signup.html", "destination": "/signup", "type": 302 },
      { "source": "/forgot-password.html", "destination": "/forgot-password", "type": 302 },
      { "source": "/access.html", "destination": "/access", "type": 302 },
      { "source": "/my-dashboard.html", "destination": "/dashboard", "type": 302 },
      { "source": "/admin.html", "destination": "/admin", "type": 302 },
      { "source": "/dzrvisit.html", "destination": "/admin/visit-management", "type": 302 },
      { "source": "/BOD Event manager/bodlogin.html", "destination": "/bod-tools", "type": 302 },
      { "source": "/events/pages-of-hope.html", "destination": "/projects", "type": 301 }
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      { "source": "/login", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/signup", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/forgot-password", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/access", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/website-guide", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/dashboard", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/bod-tools", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/visits/**", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/admin", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
      { "source": "/admin/**", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] }
    ]
  }
}
