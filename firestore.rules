rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function rolePath() {
      return /databases/$(database)/documents/roles/$(request.auth.uid);
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function websiteDirectorOccupancyPath() {
      return /databases/$(database)/documents/bodPositionOccupancy/cwd;
    }

    function presidentAssignmentPath() {
      return /databases/$(database)/documents/bodPositionAssignments/$(("president_" + request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && exists(rolePath())
        && get(rolePath()).data.role == role
        && get(rolePath()).data.get('status', 'approved') == 'approved';
    }

    function hasAnyRole(roles) {
      return signedIn()
        && exists(rolePath())
        && get(rolePath()).data.role in roles
        && get(rolePath()).data.get('status', 'approved') == 'approved';
    }

    function hasActivePresidentAssignment() {
      return hasAnyRole(['bod', 'admin', 'president'])
        && exists(userPath())
        && get(userPath()).data.get('status', '') == 'approved'
        && get(userPath()).data.get('active', true) != false
        && get(userPath()).data.get('positionKeys', []).hasAny(['president'])
        && exists(presidentAssignmentPath())
        && get(presidentAssignmentPath()).data.positionKey == 'president'
        && get(presidentAssignmentPath()).data.uid == request.auth.uid
        && get(presidentAssignmentPath()).data.active == true;
    }

    function hasWebsiteDirectorPosition() {
      return signedIn()
        && hasAnyRole(['bod', 'admin', 'president'])
        && exists(userPath())
        && get(userPath()).data.get('status', '') == 'approved'
        && get(userPath()).data.get('active', true) != false
        && get(userPath()).data.get('positionKeys', []).hasAny(['cwd'])
        && exists(websiteDirectorOccupancyPath())
        && get(websiteDirectorOccupancyPath()).data.positionKey == 'cwd'
        && get(websiteDirectorOccupancyPath()).data.active == true
        && get(websiteDirectorOccupancyPath()).data.get('holderUids', []).hasAny([request.auth.uid]);
    }

    function hasPresidentAuthority() {
      return hasActivePresidentAssignment() || hasWebsiteDirectorPosition();
    }

    function isAdmin() {
      return hasRole('admin') || hasPresidentAuthority();
    }

    function isApprovedBod() {
      return hasRole('bod') || isAdmin();
    }

    function panelLocked(panelKey) {
      return exists(/databases/$(database)/documents/locks/$(panelKey))
        && get(/databases/$(database)/documents/locks/$(panelKey)).data.locked == true;
    }

    function validBodAvenueCodes() {
      return ['ISD', 'CMD', 'CSD', 'PDD', 'RRRO', 'PRO', 'DEI', 'GBM'];
    }

    function validBodAvenueDescriptionValue(descriptions, code) {
      return !(code in descriptions)
        || (descriptions[code] is string
          && descriptions[code].size() > 0
          && descriptions[code].size() <= 2500);
    }

    function validBodAvenueDescriptions(data) {
      return data.avenueDescriptions is map
        && data.avenueDescriptions.keys().hasOnly(data.avenues)
        && data.avenueDescriptions.keys().hasAll(data.avenues)
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'ISD')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'CMD')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'CSD')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'PDD')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'RRRO')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'PRO')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'DEI')
        && validBodAvenueDescriptionValue(data.avenueDescriptions, 'GBM');
    }

    function validBodEventWrite(data) {
      return data.type == 'clubEvent'
        && data.description is string
        && data.description.size() <= 2500
        && data.desc == data.description
        && data.avenues is list
        && data.avenue is list
        && data.avenues == data.avenue
        && data.avenues.size() > 0
        && data.avenues.size() <= 8
        && data.avenues.hasOnly(validBodAvenueCodes())
        && validBodAvenueDescriptions(data);
    }

    match /roles/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /bodPositionOccupancy/{positionKey} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /bodPositionAssignments/{assignmentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rolePositionAudit/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /visitSubmissionConfig/{visitType} {
      allow read, write: if false;
    }

    match /visitSubmissionPositions/{folderId} {
      allow read, write: if false;
    }

    match /visitSubmissions/{submissionId} {
      allow read, write: if false;
    }

    match /visitSubmissionAudit/{auditId} {
      allow read, write: if false;
    }

    match /visitSubmissionFolderLocks/{folderLockId} {
      allow read, write: if false;
    }

    match /visitSubmissionUploadSessions/{sessionId} {
      allow read, write: if false;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && !panelLocked('attendance');
    }

    match /members/{memberId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('attendance');
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('attendance');
    }

    match /districtEvents/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('attendance');
    }

    match /districtAttendance/{attendanceId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('attendance');
    }

    match /bodMembers/{memberId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('bodAttendance');
    }

    match /bodMeetings/{meetingId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('bodAttendance');
    }

    match /bodAttendance/{attendanceId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('bodAttendance');
    }

    match /bodEvents/{eventId} {
      allow read: if signedIn();
      allow create, update: if isApprovedBod()
        && !panelLocked('bodEvents')
        && validBodEventWrite(request.resource.data);
      allow delete: if isApprovedBod() && !panelLocked('bodEvents');
    }

    match /fines/{fineId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('fines');
    }

    match /treasury/{transactionId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && !panelLocked('treasury');
    }

    match /locks/{panelId} {
      allow read: if signedIn();
      allow create, update, delete: if hasPresidentAuthority();
    }

    match /passwordResets/{resetId} {
      allow read, write: if false;
    }

    match /driveUploadTickets/{ticketId} {
      allow read, write: if false;
    }

    match /driveUploadRateLimits/{limitId} {
      allow read, write: if false;
    }

    match /driveUploadGroups/{groupId} {
      allow read, write: if false;
    }

    match /resolutions/{resolutionId} {
      allow read, write: if false;

      match /votes/{voterUid} {
        allow read, write: if false;
      }

      match /audit/{auditId} {
        allow read, write: if false;
      }
    }

    match /resolutionNumberIndex/{indexId} {
      allow read, write: if false;
    }

    match /resolutionPdfUploadSessions/{sessionId} {
      allow read, write: if false;
    }

    match /resolutionPdfUploadRateLimits/{limitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

